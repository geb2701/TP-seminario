    "db:seed-rankings": "tsx scripts/seed-rankings.ts",
    "db:seed-subject-rankings": "tsx scripts/seed-subject-rankings.ts",
    "db:setup": "tsx scripts/setup-turso.ts",
    "scrape:siu": "tsx scripts/scrape-siu.ts",
    "scrape:siu:transform": "tsx scripts/transform-siu-data.ts",
    "mcp": "tsx mcp/server.ts",
    "mcp:dev": "tsx watch mcp/server.ts"
  },
  "dependencies": {
