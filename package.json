{
  "name": "tp-seminario",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "cross-env TURSO_DATABASE_URL=file:./prisma/dev.db TURSO_AUTH_TOKEN= next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
