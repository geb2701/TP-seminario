generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UniversityType {
  PUBLIC
  PRIVATE
}

enum Modality {
  PRESENCIAL
  HIBRIDO
  ONLINE
}

model University {
  id               String             @id @default(cuid())
  name             String
  shortCode        String?            @unique
  city             String
  province         String
  type             UniversityType
  website          String?
  foundedYear      Int?
  description      String?
  logoUrl          String?
  careers          Career[]
  reviews          UniversityReview[]
  ranking          UniversityRanking?
  subjectRankings  UniversitySubjectRanking[]
}

// Posición de la universidad en un ranking externo (QS World University
// Rankings). La presencia de una fila marca a la universidad como "prestigiosa".
// Relacional 1:1 con University; el par (source, year) permite versionar rankings.
model UniversityRanking {
  id           String     @id @default(cuid())
  universityId String     @unique
  university   University @relation(fields: [universityId], references: [id])
  source       String     // p. ej. "QS_WORLD_2026"
  year         Int        // p. ej. 2026
  rank         Int        // clave numérica de orden = límite inferior del rango (84, 474, 801, 1201, 1401)
  rankLabel    String     // etiqueta para mostrar: "84", "801-850", "1201-1400", "1401+"

  @@unique([universityId, source, year])
}

// Posición de la universidad en un ranking QS por gran área temática (QS World
// University Rankings by Subject). Una carrera se marca "Recomendada" si su
// universidad tiene una fila para la gran área a la que la carrera pertenece.
// Relacional 1:N con University (una universidad puede figurar en varias áreas).
model UniversitySubjectRanking {
  id           String     @id @default(cuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id])
  subject      String     // ARTS_HUMANITIES | ENGINEERING_TECHNOLOGY | LIFE_SCIENCES_MEDICINE | NATURAL_SCIENCES | SOCIAL_SCIENCES_MANAGEMENT
  source       String     // p. ej. "QS_SUBJECT_2026"
  year         Int        // p. ej. 2026
  rank         Int        // clave numérica de orden = límite inferior del rango
  rankLabel    String     // etiqueta para mostrar: "24", "451-500", etc.

  @@unique([universityId, subject, source, year])
}

model Area {
  id      String   @id @default(cuid())
  name    String   @unique
  careers Career[]
}

model Career {
  id            String        @id @default(cuid())
  name          String
  durationYears Int
  degreeTitle   String
  modality      Modality      @default(PRESENCIAL)
  description   String?
  studentCount  Int           @default(0)
  universityId  String
  areaId        String
  university    University    @relation(fields: [universityId], references: [id])
  area          Area          @relation(fields: [areaId], references: [id])
  studyPlans    StudyPlan[]
  reviews       CareerReview[]
}

model StudyPlan {
  id       String    @id @default(cuid())
  name     String
  year     Int
  careerId String
  career   Career    @relation(fields: [careerId], references: [id])
  subjects Subject[]
}

model Subject {
  id          String    @id @default(cuid())
  name        String
  year        Int
  semester    Int?
  studyPlanId String
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id])
}

model CareerReview {
  id         String   @id @default(cuid())
  rating     Int
  content    String
  authorName String?
  careerId   String
  career     Career   @relation(fields: [careerId], references: [id])
  createdAt  DateTime @default(now())
}

model UniversityReview {
  id           String     @id @default(cuid())
  rating       Int
  content      String
  authorName   String?
  universityId String
  university   University @relation(fields: [universityId], references: [id])
  createdAt    DateTime   @default(now())
}

model VocationalResult {
  id         String   @id @default(cuid())
  personName String?
  scores     String
  topArea    String
  createdAt  DateTime @default(now())
}
